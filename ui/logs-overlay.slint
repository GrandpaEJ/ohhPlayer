export component LogsOverlay inherits Rectangle {
    in property <[string]> logs;
    callback close-logs;
    
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.7);

    TouchArea {
        clicked => { root.close-logs(); }
    }

    Rectangle {
        width: min(800px, parent.width - 40px);
        height: min(400px, parent.height - 40px);
        background: rgba(20, 20, 28, 0.95);
        border-radius: 8px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
        drop-shadow-blur: 16px;
        drop-shadow-color: rgba(0, 0, 0, 0.8);

        TouchArea {} // Block clicks from closing overlay

        VerticalLayout {
            padding: 16px;
            spacing: 8px;

            HorizontalLayout {
                Text {
                    text: "System Logs";
                    color: #fff;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                TouchArea {
                    width: 24px; height: 24px;
                    clicked => { root.close-logs(); }
                    Text {
                        text: "✕";
                        color: parent.has-hover ? #f44 : #ccc;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                background: rgba(0, 0, 0, 0.5);
                border-radius: 4px;
                border-width: 1px;
                border-color: rgba(255, 255, 255, 0.05);
                clip: true;

                Flickable {
                    viewport-height: log_layout.preferred-height;
                    
                    log_layout := VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        for line in root.logs: Text {
                            text: line;
                            color: #0f0;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
