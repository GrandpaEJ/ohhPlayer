export component SeekBar {
    in-out property <float> slider-value;
    in property <bool> block-slider-update;
    callback seeked(float);
    callback controls-moved;

    height: 18px;

    seek-ta := TouchArea {
        pointer-event(evt) => {
            root.controls-moved();
            if evt.kind == PointerEventKind.move && self.pressed {
                let v = max(0, min(1, self.mouse-x / parent.width));
                if !root.block-slider-update { root.seeked(v); }
            }
        }
        clicked => {
            root.controls-moved();
            root.seeked(max(0, min(1, self.mouse-x / parent.width)));
        }
    }

    // Track background
    Rectangle {
        y: (parent.height - 4px) / 2;
        height: seek-ta.has_hover ? 6px : 4px;
        width: 100%;
        border-radius: 3px;
        background: rgba(255,255,255,0.18);
        animate height { duration: 120ms; easing: ease-out; }
    }
    // Filled portion
    Rectangle {
        y: (parent.height - (seek-ta.has_hover ? 6px : 4px)) / 2;
        x: 0;
        height: seek-ta.has_hover ? 6px : 4px;
        width: parent.width * root.slider-value;
        border-radius: 3px;
        background: @linear-gradient(90deg, #5ba4f5, #a78bfa);
        animate height { duration: 120ms; easing: ease-out; }
    }
    // Thumb — only visible on hover
    Rectangle {
        x: parent.width * root.slider-value - 7px;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        border-radius: 7px;
        background: #fff;
        opacity: seek-ta.has_hover ? 1.0 : 0.0;
        drop-shadow-blur: 4px;
        drop-shadow-color: rgba(90,160,255,0.6);
        animate opacity { duration: 150ms; }
    }
}
