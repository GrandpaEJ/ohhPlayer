export component SkipButton inherits Rectangle {
    in property <string> icon-text;
    in property <string> duration-text;
    callback clicked;
    callback controls-moved;

    width: 34px; height: 36px;
    border-radius: 6px;
    background: skip-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
    animate background { duration: 120ms; }

    Text {
        text: root.icon-text;
        color: rgba(255,255,255,0.75);
        font-size: 18px;
        x: (parent.width - self.preferred-width) / 2;
        y: (parent.height - self.preferred-height) / 2;
    }
    Text {
        text: root.duration-text;
        color: rgba(255,255,255,0.75);
        font-size: 7px;
        x: (parent.width - self.preferred-width) / 2 + 1px;
        y: (parent.height - self.preferred-height) / 2 + 4px;
    }
    skip-ta := TouchArea {
        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
        clicked => { root.clicked(); root.controls-moved(); }
    }
}
