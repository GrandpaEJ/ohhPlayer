export component OsdOverlay {
    in property <string> text;
    in property <float> osd-opacity;

    width: 100%; height: 100%;

    Rectangle {
        x: (parent.width - self.preferred-width) / 2;
        y: 40px; // near top
        width: txt.preferred-width + 32px;
        height: txt.preferred-height + 16px;
        background: rgba(0, 0, 0, 0.65);
        border-radius: 8px;
        opacity: root.osd-opacity;
        
        animate opacity { duration: 150ms; }

        txt := Text {
            text: root.text;
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            x: (parent.width - self.preferred-width) / 2;
            y: (parent.height - self.preferred-height) / 2;
        }
    }
}
