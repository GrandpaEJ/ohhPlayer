import { Slider, HorizontalBox } from "std-widgets.slint";

export component Controls {
    in-out property <bool> playing;
    in-out property <string> time-text;
    in-out property <float> slider-value;
    in-out property <bool> block-slider-update;
    in-out property <float> volume-level;
    in-out property <bool> is-fullscreen;

    callback play-paused;
    callback seeked(float);
    callback fullscreen-toggled;
    callback volume-toggled;
    callback close-window;
    callback controls-moved;

    Rectangle {
        width: 100%;
        height: 100%;
        background: rgba(8, 8, 18, 0.88);

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 40px; height: 36px;
                background: rgba(255, 255, 255, 0.06);

                Text {
                    text: root.playing ? "⏸" : "▶";
                    color: #eee;
                    font-size: 17px;
                    x: (parent.width - self.preferred-width) / 2;
                    y: (parent.height - self.preferred-height) / 2;
                }

                TouchArea {
                    moved => { root.controls-moved(); }
                    clicked => { root.play-paused(); }
                }
            }

            Text {
                text: root.time-text;
                color: #aaa;
                font-size: 12px;
                vertical-alignment: center;
                min-width: 105px;
                horizontal-alignment: center;
            }

            Slider {
                minimum: 0;
                maximum: 1;
                value: root.slider-value;
                changed(new-val) => {
                    root.controls-moved();
                    if !root.block-slider-update {
                        root.seeked(new-val);
                    }
                }
            }

            Rectangle {
                width: 28px; height: 28px;

                Text {
                    text: root.volume-level > 0 ? "🔊" : "🔇";
                    color: #ccc;
                    font-size: 14px;
                    x: (parent.width - self.preferred-width) / 2;
                    y: (parent.height - self.preferred-height) / 2;
                }

                TouchArea {
                    moved => { root.controls-moved(); }
                    clicked => { root.volume-toggled(); }
                }
            }

            Rectangle {
                width: 36px; height: 36px;
                background: rgba(255, 255, 255, 0.06);

                Text {
                    text: root.is-fullscreen ? "⧉" : "⛶";
                    color: #ccc;
                    font-size: 15px;
                    x: (parent.width - self.preferred-width) / 2;
                    y: (parent.height - self.preferred-height) / 2;
                }

                TouchArea {
                    moved => { root.controls-moved(); }
                    clicked => { root.fullscreen-toggled(); }
                }
            }

            Rectangle {
                width: 36px; height: 36px;
                background: rgba(255, 255, 255, 0.06);

                Text {
                    text: "✕";
                    color: #e55;
                    font-size: 15px;
                    x: (parent.width - self.preferred-width) / 2;
                    y: (parent.height - self.preferred-height) / 2;
                }

                TouchArea {
                    moved => { root.controls-moved(); }
                    clicked => { root.close-window(); }
                }
            }
        }
    }
}
