import { SeekBar } from "./controls-seek-bar.slint";
import { SpeedPopup } from "./controls-speed-popup.slint";
import { PlayButton } from "./controls-play-button.slint";
import { SkipButton } from "./controls-skip-button.slint";
import { VolumeControl } from "./controls-volume.slint";
import { SpeedButton } from "./controls-speed-button.slint";
import { ScaleButton } from "./controls-scale-button.slint";
import { FullscreenButton } from "./controls-fullscreen-button.slint";

// Production-grade controls: seek bar on top, button row below.
// Window management (min/max/close) removed — handled by the OS title bar.

export component Controls {
    in-out property <bool>   playing;
    in-out property <string> time-text;
    in-out property <float>  slider-value;
    in-out property <bool>   block-slider-update;
    in-out property <float>  volume-level;
    in-out property <bool>   is-fullscreen;
    in-out property <float>  speed: 1.0;
    in-out property <int>    scale-mode;

    callback play-paused;
    callback seeked(float);
    callback seek-relative(float);
    callback fullscreen-toggled;
    callback volume-toggled;
    callback volume-changed(float);
    callback speed-changed(float);
    callback controls-moved;

    property <bool> speed-open: false;

    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%; height: 100%;
        background: @linear-gradient(0deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.55) 70%, transparent 100%);

        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 8px;
            padding-bottom: 10px;
            spacing: 6px;
            alignment: end;

            // ── ROW 1: Seek bar ──────────────────────────────────────────
            SeekBar {
                slider-value <=>        root.slider-value;
                block-slider-update <=> root.block-slider-update;
                seeked(val)          => { root.seeked(val); }
                controls-moved       => { root.controls-moved(); }
            }

            // ── ROW 2: Button row ────────────────────────────────────────
            HorizontalLayout {
                spacing: 4px;
                alignment: start;
                height: 36px;

                // ── Left cluster ─────────────────────────────────────────

                // Play / Pause
                PlayButton {
                    playing <=> root.playing;
                    clicked => { root.play-paused(); }
                    controls-moved => { root.controls-moved(); }
                }

                // Skip −10 s
                SkipButton {
                    icon-text: "↺";
                    duration-text: "10";
                    clicked => { root.seek-relative(-10); }
                    controls-moved => { root.controls-moved(); }
                }

                // Skip +10 s
                SkipButton {
                    icon-text: "↻";
                    duration-text: "10";
                    clicked => { root.seek-relative(10); }
                    controls-moved => { root.controls-moved(); }
                }

                // Volume control (Icon + Slider)
                VolumeControl {
                    volume-level <=> root.volume-level;
                    volume-toggled => { root.volume-toggled(); }
                    volume-changed(v) => { root.volume-changed(v); }
                    controls-moved => { root.controls-moved(); }
                }

                // Time display
                Text {
                    text: root.time-text;
                    color: rgba(255,255,255,0.6);
                    font-size: 12px;
                    vertical-alignment: center;
                    min-width: 110px;
                    horizontal-alignment: left;
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // ── Right cluster ─────────────────────────────────────────

                // Speed selector button
                SpeedButton {
                    speed: root.speed;
                    speed-open <=> root.speed-open;
                    clicked => { }
                    controls-moved => { root.controls-moved(); }
                }

                // Scale mode toggle button
                ScaleButton {
                    scale-mode <=> root.scale-mode;
                    clicked => { } // Already updates its own property
                    controls-moved => { root.controls-moved(); }
                }

                // Fullscreen button
                FullscreenButton {
                    is-fullscreen <=> root.is-fullscreen;
                    clicked => { root.fullscreen-toggled(); }
                    controls-moved => { root.controls-moved(); }
                }
            }
        }

        // ── Speed popup (floats above the button row) ─────────────────────
        SpeedPopup {
            speed <=> root.speed;
            speed-open <=> root.speed-open;
            speed-changed(val) => { root.speed = val; root.speed-changed(val); root.speed-open = false; }
            controls-moved     => { root.controls-moved(); }
        }
    }
}
