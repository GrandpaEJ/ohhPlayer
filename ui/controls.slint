import { SeekBar } from "./controls-seek-bar.slint";
import { SpeedPopup } from "./controls-speed-popup.slint";

// Production-grade controls: seek bar on top, button row below.
// Window management (min/max/close) removed — handled by the OS title bar.

export component Controls {
    in-out property <bool>   playing;
    in-out property <string> time-text;
    in-out property <float>  slider-value;
    in-out property <bool>   block-slider-update;
    in-out property <float>  volume-level;
    in-out property <bool>   is-fullscreen;
    in-out property <float>  speed: 1.0;
    in-out property <int>    scale-mode;

    callback play-paused;
    callback seeked(float);
    callback seek-relative(float);
    callback fullscreen-toggled;
    callback volume-toggled;
    callback volume-changed(float);
    callback speed-changed(float);
    callback controls-moved;

    property <bool> speed-open: false;

    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%; height: 100%;
        background: @linear-gradient(0deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.55) 70%, transparent 100%);

        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 8px;
            padding-bottom: 10px;
            spacing: 6px;
            alignment: end;

            // ── ROW 1: Seek bar ──────────────────────────────────────────
            SeekBar {
                slider-value <=>        root.slider-value;
                block-slider-update <=> root.block-slider-update;
                seeked(val)          => { root.seeked(val); }
                controls-moved       => { root.controls-moved(); }
            }

            // ── ROW 2: Button row ────────────────────────────────────────
            HorizontalLayout {
                spacing: 4px;
                alignment: start;
                height: 36px;

                // ── Left cluster ─────────────────────────────────────────

                // Play / Pause
                Rectangle {
                    width: 36px; height: 36px;
                    border-radius: 6px;
                    background: play-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: root.playing ? "⏸" : "▶";
                        color: #fff;
                        font-size: 16px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    play-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.play-paused(); }
                    }
                }

                // Skip −10 s
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: skip-back-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: "↺";
                        color: rgba(255,255,255,0.75);
                        font-size: 18px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    Text {
                        text: "10";
                        color: rgba(255,255,255,0.75);
                        font-size: 7px;
                        x: (parent.width - self.preferred-width) / 2 + 1px;
                        y: (parent.height - self.preferred-height) / 2 + 4px;
                    }
                    skip-back-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.seek-relative(-10); root.controls-moved(); }
                    }
                }

                // Skip +10 s
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: skip-fwd-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: "↻";
                        color: rgba(255,255,255,0.75);
                        font-size: 18px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    Text {
                        text: "10";
                        color: rgba(255,255,255,0.75);
                        font-size: 7px;
                        x: (parent.width - self.preferred-width) / 2 + 1px;
                        y: (parent.height - self.preferred-height) / 2 + 4px;
                    }
                    skip-fwd-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.seek-relative(10); root.controls-moved(); }
                    }
                }

                // Volume icon (mute toggle)
                Rectangle {
                    width: 30px; height: 36px;
                    border-radius: 6px;
                    background: vol-icon-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: root.volume-level > 0.5 ? "🔊"
                            : root.volume-level > 0   ? "🔉"
                            :                           "🔇";
                        color: rgba(255,255,255,0.75);
                        font-size: 14px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    vol-icon-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.volume-toggled(); }
                    }
                }

                // Volume slider (compact)
                Rectangle {
                    width: 72px; height: 36px;

                    vol-ta := TouchArea {
                        pointer-event(evt) => {
                            root.controls-moved();
                            if evt.kind == PointerEventKind.move && self.pressed {
                                root.volume-changed(max(0, min(1, self.mouse-x / parent.width)));
                            }
                        }
                        clicked => {
                            root.volume-changed(max(0, min(1, self.mouse-x / parent.width)));
                        }
                    }
                    // Track
                    Rectangle {
                        y: (parent.height - 3px) / 2;
                        height: 3px; width: 100%;
                        border-radius: 2px;
                        background: rgba(255,255,255,0.18);
                    }
                    // Fill
                    Rectangle {
                        y: (parent.height - 3px) / 2;
                        height: 3px;
                        width: parent.width * root.volume-level;
                        border-radius: 2px;
                        background: vol-ta.has_hover ? rgba(255,255,255,0.9) : rgba(255,255,255,0.7);
                        animate background { duration: 120ms; }
                    }
                    // Thumb — pops and scales up on hover
                    Rectangle {
                        x: parent.width * root.volume-level - (vol-ta.has_hover || vol-ta.pressed ? 6px : 0px);
                        y: (parent.height - (vol-ta.has_hover || vol-ta.pressed ? 12px : 0px)) / 2;
                        width: vol-ta.has_hover || vol-ta.pressed ? 12px : 0px;
                        height: vol-ta.has_hover || vol-ta.pressed ? 12px : 0px;
                        border-radius: vol-ta.has_hover || vol-ta.pressed ? 6px : 0px;
                        background: #fff;
                        opacity: vol-ta.has_hover || vol-ta.pressed ? 1.0 : 0.0;
                        drop-shadow-blur: 4px;
                        drop-shadow-color: rgba(255, 255, 255, 0.4);
                        animate width, height, x, y, border-radius, opacity { duration: 150ms; easing: cubic-bezier(0.175, 0.885, 0.32, 1.275); }
                    }
                }

                // Time display
                Text {
                    text: root.time-text;
                    color: rgba(255,255,255,0.6);
                    font-size: 12px;
                    vertical-alignment: center;
                    min-width: 110px;
                    horizontal-alignment: left;
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // ── Right cluster ─────────────────────────────────────────

                // Speed selector button
                Rectangle {
                    width: 44px; height: 28px;
                    border-radius: 5px;
                    background: speed-open
                        ? rgba(90,160,255,0.22)
                        : spd-ta.has_hover
                            ? rgba(255,255,255,0.14)
                            : rgba(255,255,255,0.08);
                    border-color: speed-open
                        ? rgba(90,160,255,0.5)
                        : rgba(255,255,255,0.12);
                    border-width: 1px;
                    animate background { duration: 120ms; }

                    Text {
                        text: root.speed == 1.0  ? "1× "
                            : root.speed == 0.25 ? ".25×"
                            : root.speed == 0.5  ? ".5× "
                            : root.speed == 0.75 ? ".75×"
                            : root.speed == 1.25 ? "1.25"
                            : root.speed == 1.5  ? "1.5×"
                            :                      "2×  ";
                        color: speed-open ? #7ab4ff : rgba(255,255,255,0.8);
                        font-size: 11px;
                        font-weight: 600;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    spd-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.speed-open = !root.speed-open; root.controls-moved(); }
                    }
                }

                // Scale mode toggle button
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: scale-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: root.scale-mode == 0 ? "🔲" : (root.scale-mode == 1 ? "↔️" : (root.scale-mode == 2 ? "🔍" : "1:1"));
                        color: rgba(255,255,255,0.75);
                        font-size: root.scale-mode == 3 ? 10px : 14px;
                        font-weight: 600;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    scale-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => {
                            root.scale-mode = root.scale-mode == 0 ? 1 : (root.scale-mode == 1 ? 2 : (root.scale-mode == 2 ? 3 : 0));
                            root.controls-moved();
                        }
                    }
                }

                // Fullscreen button
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: fs-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
                    animate background { duration: 120ms; }

                    Text {
                        text: root.is-fullscreen ? "⊠" : "⛶";
                        color: rgba(255,255,255,0.75);
                        font-size: 16px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    fs-ta := TouchArea {
                        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                        clicked => { root.fullscreen-toggled(); }
                    }
                }
            }
        }

        // ── Speed popup (floats above the button row) ─────────────────────
        SpeedPopup {
            speed <=> root.speed;
            speed-open <=> root.speed-open;
            speed-changed(val) => { root.speed = val; root.speed-changed(val); root.speed-open = false; }
            controls-moved     => { root.controls-moved(); }
        }
    }
}
