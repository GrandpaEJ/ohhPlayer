// Production-grade controls: seek bar on top, button row below.
// Window management (min/max/close) removed — handled by the OS title bar.

export component Controls {
    in-out property <bool>   playing;
    in-out property <string> time-text;
    in-out property <float>  slider-value;
    in-out property <bool>   block-slider-update;
    in-out property <float>  volume-level;
    in-out property <bool>   is-fullscreen;
    in-out property <float>  speed: 1.0;

    callback play-paused;
    callback seeked(float);
    callback seek-relative(float);
    callback fullscreen-toggled;
    callback volume-toggled;
    callback volume-changed(float);
    callback speed-changed(float);
    callback controls-moved;

    property <bool>  speed-open: false;
    property <bool>  vol-hovered: false;
    property <float> seek-hover-x: 0;

    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%; height: 100%;
        // Subtle gradient from transparent → dark
        background: @linear-gradient(0deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.55) 70%, transparent 100%);

        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 8px;
            padding-bottom: 10px;
            spacing: 6px;
            alignment: end;

            // ── ROW 1: Seek bar ──────────────────────────────────────────
            Rectangle {
                height: 18px;

                // Track background
                Rectangle {
                    y: (parent.height - 4px) / 2;
                    height: 4px;
                    width: 100%;
                    border-radius: 2px;
                    background: rgba(255,255,255,0.18);
                }

                // Filled portion
                Rectangle {
                    y: (parent.height - 4px) / 2;
                    x: 0;
                    height: 4px;
                    width: parent.width * root.slider-value;
                    border-radius: 2px;
                    background: @linear-gradient(90deg, #5ba4f5, #a78bfa);
                }

                // Thumb handle
                Rectangle {
                    x: parent.width * root.slider-value - 7px;
                    y: (parent.height - 14px) / 2;
                    width: 14px;
                    height: 14px;
                    border-radius: 7px;
                    background: #fff;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: rgba(90,160,255,0.6);
                }

                // Touch area over entire seek row
                TouchArea {
                    moved => {
                        root.controls-moved();
                        if self.pressed {
                            let v = (self.mouse-x / parent.width).clamp(0, 1);
                            if !root.block-slider-update { root.seeked(v); }
                        }
                    }
                    clicked => {
                        root.controls-moved();
                        let v = (self.mouse-x / parent.width).clamp(0, 1);
                        root.seeked(v);
                    }
                }
            }

            // ── ROW 2: Button row ────────────────────────────────────────
            HorizontalLayout {
                spacing: 4px;
                alignment: start;
                height: 36px;

                // ── Left cluster ─────────────────────────────────────────

                // Play / Pause
                Rectangle {
                    width: 36px; height: 36px;
                    border-radius: 6px;
                    background: rgba(255,255,255,0.0);

                    animate background { duration: 150ms; }

                    Text {
                        text: root.playing ? "⏸" : "▶";
                        color: #fff;
                        font-size: 16px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.play-paused(); }
                    }
                }

                // Skip −10 s
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: rgba(255,255,255,0.0);

                    Text {
                        text: "↺";
                        color: rgba(255,255,255,0.75);
                        font-size: 18px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    // small "10" label
                    Text {
                        text: "10";
                        color: rgba(255,255,255,0.75);
                        font-size: 7px;
                        x: (parent.width - self.preferred-width) / 2 + 1px;
                        y: (parent.height - self.preferred-height) / 2 + 4px;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.seek-relative(-10); root.controls-moved(); }
                    }
                }

                // Skip +10 s
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;
                    background: rgba(255,255,255,0.0);

                    Text {
                        text: "↻";
                        color: rgba(255,255,255,0.75);
                        font-size: 18px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    Text {
                        text: "10";
                        color: rgba(255,255,255,0.75);
                        font-size: 7px;
                        x: (parent.width - self.preferred-width) / 2 + 1px;
                        y: (parent.height - self.preferred-height) / 2 + 4px;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.seek-relative(10); root.controls-moved(); }
                    }
                }

                // Volume icon (mute toggle)
                Rectangle {
                    width: 30px; height: 36px;

                    Text {
                        text: root.volume-level > 0.5 ? "🔊"
                            : root.volume-level > 0   ? "🔉"
                            :                           "🔇";
                        color: rgba(255,255,255,0.75);
                        font-size: 14px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.volume-toggled(); }
                    }
                }

                // Volume slider (compact)
                Rectangle {
                    width: 72px; height: 36px;

                    // Track
                    Rectangle {
                        y: (parent.height - 3px) / 2;
                        height: 3px; width: 100%;
                        border-radius: 2px;
                        background: rgba(255,255,255,0.18);
                    }
                    // Fill
                    Rectangle {
                        y: (parent.height - 3px) / 2;
                        height: 3px;
                        width: parent.width * root.volume-level;
                        border-radius: 2px;
                        background: rgba(255,255,255,0.7);
                    }
                    // Thumb
                    Rectangle {
                        x: parent.width * root.volume-level - 6px;
                        y: (parent.height - 12px) / 2;
                        width: 12px; height: 12px;
                        border-radius: 6px;
                        background: #fff;
                    }
                    TouchArea {
                        moved    => {
                            root.controls-moved();
                            if self.pressed {
                                root.volume-changed((self.mouse-x / parent.width).clamp(0, 1));
                            }
                        }
                        clicked  => {
                            root.volume-changed((self.mouse-x / parent.width).clamp(0, 1));
                        }
                    }
                }

                // Time display
                Text {
                    text: root.time-text;
                    color: rgba(255,255,255,0.6);
                    font-size: 12px;
                    vertical-alignment: center;
                    min-width: 110px;
                    horizontal-alignment: left;
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // ── Right cluster ─────────────────────────────────────────

                // Speed selector button
                Rectangle {
                    width: 44px; height: 28px;
                    border-radius: 5px;
                    background: speed-open
                        ? rgba(90,160,255,0.22)
                        : rgba(255,255,255,0.08);
                    border-color: speed-open
                        ? rgba(90,160,255,0.5)
                        : rgba(255,255,255,0.12);
                    border-width: 1px;

                    animate background { duration: 120ms; }

                    Text {
                        text: root.speed == 1.0  ? "1× "
                            : root.speed == 0.25 ? ".25×"
                            : root.speed == 0.5  ? ".5× "
                            : root.speed == 0.75 ? ".75×"
                            : root.speed == 1.25 ? "1.25"
                            : root.speed == 1.5  ? "1.5×"
                            :                      "2×  ";
                        color: speed-open ? #7ab4ff : rgba(255,255,255,0.8);
                        font-size: 11px;
                        font-weight: 600;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.speed-open = !root.speed-open; root.controls-moved(); }
                    }
                }

                // Fullscreen button
                Rectangle {
                    width: 34px; height: 36px;
                    border-radius: 6px;

                    Text {
                        text: root.is-fullscreen ? "⊠" : "⛶";
                        color: rgba(255,255,255,0.75);
                        font-size: 16px;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    TouchArea {
                        moved    => { root.controls-moved(); }
                        clicked  => { root.fullscreen-toggled(); }
                    }
                }
            }
        }

        // ── Speed popup (floats above the button row) ─────────────────────
        if speed-open : Rectangle {
            x: parent.width - 110px;
            y: -168px;
            width: 110px;
            height: 162px;
            background: rgba(14, 14, 26, 0.96);
            border-radius: 8px;
            border-color: rgba(255, 255, 255, 0.10);
            border-width: 1px;
            drop-shadow-blur: 16px;
            drop-shadow-color: rgba(0,0,0,0.6);

            VerticalLayout {
                padding: 6px;
                spacing: 1px;

                for spd in [0.25, 0.5, 0.75, 1.0, 1.25, 1.5, 2.0] : Rectangle {
                    height: 26px;
                    border-radius: 5px;
                    background: spd == root.speed
                        ? rgba(90, 160, 255, 0.20)
                        : rgba(255,255,255,0.0);

                    animate background { duration: 100ms; }

                    Text {
                        text: spd == 1.0  ? "Normal (1×)"
                            : spd == 0.25 ? "0.25×"
                            : spd == 0.5  ? "0.5×"
                            : spd == 0.75 ? "0.75×"
                            : spd == 1.25 ? "1.25×"
                            : spd == 1.5  ? "1.5×"
                            : "2×";
                        color: spd == root.speed ? #7ab4ff : rgba(255,255,255,0.75);
                        font-size: 12px;
                        font-weight: spd == root.speed ? 700 : 400;
                        x: 10px;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                    TouchArea {
                        clicked => {
                            root.speed = spd;
                            root.speed-changed(spd);
                            root.speed-open = false;
                            root.controls-moved();
                        }
                    }
                }
            }
        }
    }
}
