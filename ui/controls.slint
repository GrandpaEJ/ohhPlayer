import { SeekBar } from "./controls-seek-bar.slint";
import { SpeedPopup } from "./controls-speed-popup.slint";
import { PlayButton } from "./controls-play-button.slint";
import { SkipButton } from "./controls-skip-button.slint";
import { VolumeControl } from "./controls-volume.slint";
import { SpeedButton } from "./controls-speed-button.slint";
import { ScaleButton } from "./controls-scale-button.slint";
import { FullscreenButton } from "./controls-fullscreen-button.slint";
import { SleepTimerPopup } from "./sleep-timer-popup.slint";

// Production-grade controls: seek bar on top, button row below.
// Window management (min/max/close) removed — handled by the OS title bar.

export component Controls {
    in-out property <bool>   playing;
    in-out property <string> time-text;
    in-out property <float>  slider-value;
    in-out property <bool>   block-slider-update;
    in-out property <float>  volume-level;
    in-out property <bool>   is-fullscreen;
    in-out property <float>  speed: 1.0;
    in-out property <int>    scale-mode;
    in-out property <bool>   always-on-top;
    in-out property <int>    sleep-timer-val;

    callback play-paused;
    callback seeked(float);
    callback seek-dragging(float);
    callback seek-ended(float);
    callback seek-relative(float);
    callback fullscreen-toggled;
    callback volume-toggled;
    callback volume-changed(float);
    callback speed-changed(float);
    callback controls-moved;
    callback always-on-top-toggled;
    callback sleep-timer-changed(int);
    callback custom-timer-requested(string);
    callback scale-mode-changed(int);

    property <bool> speed-open: false;
    property <bool> sleep-timer-open: false;

    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%; height: 100%;
        background: @linear-gradient(0deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.55) 70%, transparent 100%);

        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 12px;
            padding-bottom: 21px;
            spacing: 12px;
            alignment: end;

            // ── ROW 1: Seek bar ──────────────────────────────────────────
            SeekBar {
                slider-value <=>        root.slider-value;
                block-slider-update <=> root.block-slider-update;
                seeked(val)          => { root.seeked(val); }
                seek-dragging(val)   => { root.seek-dragging(val); }
                seek-ended(val)      => { root.seek-ended(val); }
                controls-moved       => { root.controls-moved(); }
            }

            // ── ROW 2: Button row ────────────────────────────────────────
            HorizontalLayout {
                spacing: 12px;
                height: 48px; // Increased slightly for pill padding

                // ── Left cluster ─────────────────────────────────────────

                // Play / Pause group
                Rectangle {
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.05);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.08);
                    HorizontalLayout {
                        padding: 4px;
                        PlayButton {
                            playing <=> root.playing;
                            clicked => { root.play-paused(); }
                            controls-moved => { root.controls-moved(); }
                        }
                    }
                }

                // Skip buttons group
                Rectangle {
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.05);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.08);
                    HorizontalLayout {
                        padding: 4px;
                        spacing: 4px;
                        SkipButton {
                            is-forward: false;
                            duration-text: "10";
                            clicked => { root.seek-relative(-10); }
                            controls-moved => { root.controls-moved(); }
                        }
                        SkipButton {
                            is-forward: true;
                            duration-text: "10";
                            clicked => { root.seek-relative(10); }
                            controls-moved => { root.controls-moved(); }
                        }
                    }
                }

                // Volume control group
                Rectangle {
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.05);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.08);
                    HorizontalLayout {
                        padding: 4px;
                        VolumeControl {
                            volume-level <=> root.volume-level;
                            volume-toggled => { root.volume-toggled(); }
                            volume-changed(v) => { root.volume-changed(v); }
                            controls-moved => { root.controls-moved(); }
                        }
                    }
                }

                // Time display
                Text {
                    text: root.time-text;
                    color: rgba(255,255,255,0.6);
                    font-size: 12px;
                    vertical-alignment: center;
                    min-width: 110px;
                    horizontal-alignment: left;
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // ── Right cluster ─────────────────────────────────────────
                Rectangle {
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.05);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.08);
                    HorizontalLayout {
                        padding: 4px;
                        spacing: 4px;

                        // Always On Top button
                        Rectangle {
                            width: 40px; height: 40px; border-radius: 6px;
                            background: aot-ta.has_hover ? rgba(255,255,255,0.1) : transparent;
                            animate background { duration: 150ms; }
                            Path {
                                width: 20px; height: 22px;
                                stroke: root.always-on-top ? #0cf : #ccc;
                                stroke-width: 1.5px;
                                fill: transparent;
                                commands: "M 7 2 L 13 2 L 13 6 L 16 10 L 16 14 L 11 14 L 11 20 L 9 20 L 9 14 L 4 14 L 4 10 L 7 6 Z";
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                            aot-ta := TouchArea {
                                clicked => { root.always-on-top-toggled(); }
                                pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                            }
                        }

                        // Sleep Timer button
                        Rectangle {
                            width: 40px; height: 40px; border-radius: 6px;
                            background: sleep-ta.has_hover ? rgba(255,255,255,0.1) : transparent;
                            animate background { duration: 150ms; }
                            Path {
                                width: 20px; height: 20px;
                                stroke: root.sleep-timer-val > 0 ? #0cf : #ccc;
                                stroke-width: 1.5px;
                                fill: transparent;
                                commands: "M 10 1 A 9 9 0 1 0 10.001 1 Z M 10 4 L 10 10 L 13 13";
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                            sleep-ta := TouchArea {
                                clicked => { root.sleep-timer-open = !root.sleep-timer-open; root.speed-open = false; }
                                pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                            }
                        }

                        // Speed selector button
                        SpeedButton {
                            speed: root.speed;
                            speed-open <=> root.speed-open;
                            clicked => { }
                            controls-moved => { root.controls-moved(); }
                        }

                        // Scale mode toggle button
                        ScaleButton {
                            scale-mode <=> root.scale-mode;
                            clicked => { root.scale-mode-changed(root.scale-mode); }
                            controls-moved => { root.controls-moved(); }
                        }

                        // Fullscreen button
                        FullscreenButton {
                            is-fullscreen <=> root.is-fullscreen;
                            clicked => { root.fullscreen-toggled(); }
                            controls-moved => { root.controls-moved(); }
                        }
                    }
                }
            }
        }

        // ── Speed popup (floats above the button row) ─────────────────────
        SpeedPopup {
            speed <=> root.speed;
            speed-open <=> root.speed-open;
            speed-changed(val) => { root.speed = val; root.speed-changed(val); root.speed-open = false; }
            controls-moved     => { root.controls-moved(); }
        }

        // ── Sleep Timer popup ──────────────────────────────────────────────
        SleepTimerPopup {
            x: parent.width - 150px;
            y: -205px;
            active-timer <=> root.sleep-timer-val;
            is-open <=> root.sleep-timer-open;
            timer-selected(val) => { root.sleep-timer-val = val; root.sleep-timer-changed(val); root.sleep-timer-open = false; }
            custom-timer-requested(val) => { root.custom-timer-requested(val); root.sleep-timer-open = false; }
            controls-moved => { root.controls-moved(); }
        }
    }
}
