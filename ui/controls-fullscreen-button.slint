export component FullscreenButton inherits Rectangle {
    in-out property <bool> is-fullscreen;
    callback clicked;
    callback controls-moved;

    width: 40px; height: 40px;
    border-radius: 6px;
    background: fs-ta.has_hover ? rgba(255,255,255,0.14) : rgba(255,255,255,0.0);
    animate background { duration: 120ms; }

    Path {
        width: 22px; height: 22px;
        fill: rgba(255,255,255,0.75);
        commands: root.is-fullscreen 
            ? "M 8 8 L 2 8 L 2 6 L 6 6 L 6 2 L 8 2 Z M 14 8 L 20 8 L 20 6 L 16 6 L 16 2 L 14 2 Z M 8 14 L 2 14 L 2 16 L 6 16 L 6 20 L 8 20 Z M 14 14 L 20 14 L 20 16 L 16 16 L 16 20 L 14 20 Z" 
            : "M 2 2 L 8 2 L 8 4 L 4 4 L 4 8 L 2 8 Z M 20 2 L 14 2 L 14 4 L 18 4 L 18 8 L 20 8 Z M 2 20 L 8 20 L 8 18 L 4 18 L 4 14 L 2 14 Z M 20 20 L 14 20 L 14 18 L 18 18 L 18 14 L 20 14 Z";
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
    fs-ta := TouchArea {
        pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
        clicked => { root.clicked(); root.controls-moved(); }
    }
}
