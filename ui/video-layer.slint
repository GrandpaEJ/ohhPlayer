export component VideoLayer {
    in property <image> frame;
    in property <int> scale-mode: 1;
    width: 100%; height: 100%;

    // Video frame
    Image {
        source: root.frame;
        width: 100%; height: 100%;
        image-fit: root.scale-mode == 0 ? ImageFit.contain : (root.scale-mode == 1 ? ImageFit.fill : ImageFit.cover);
    }

    // Dark vignette at bottom (behind controls)
    Rectangle {
        x: 0; y: parent.height - 120px;
        width: 100%; height: 120px;
        background: @linear-gradient(0deg, rgba(0,0,0,0.65) 0%, transparent 100%);
    }
}
