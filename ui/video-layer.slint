export component VideoLayer {
    in property <image> frame;
    in property <int> scale-mode: 1;
    width: 100%; height: 100%;

    // Scaled modes (0=Fit, 1=Stretch, 2=Zoom)
    if root.scale-mode < 3: Image {
        source: root.frame;
        width: 100%; height: 100%;
        image-fit: root.scale-mode == 0 ? ImageFit.contain : (root.scale-mode == 1 ? ImageFit.fill : ImageFit.cover);
    }

    // 100% Original Size mode (unscaled, centered, cropped if overflows)
    if root.scale-mode == 3: Rectangle {
        width: 100%; height: 100%;
        clip: true;
        Image {
            source: root.frame;
            width: root.frame.width * 1px;
            height: root.frame.height * 1px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: ImageFit.fill; // Explicitly fill the exact native dimension box
        }
    }

    // Forced Aspect Ratio modes (4=1:1, 5=16:9, 6=9:16)
    if root.scale-mode >= 4: Rectangle {
        width: 100%; height: 100%;
        
        property <float> target-ratio: root.scale-mode == 4 ? 1.0 : (root.scale-mode == 5 ? 1.7777778 : 0.5625);
        property <float> window-ratio: parent.height > 0 ? (parent.width / parent.height) : 1.0;

        Rectangle {
            width: window-ratio > target-ratio ? parent.height * target-ratio : parent.width;
            height: target-ratio > 0 ? (window-ratio > target-ratio ? parent.height : parent.width / target-ratio) : parent.height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;

            Image {
                source: root.frame;
                width: 100%; height: 100%;
                image-fit: ImageFit.fill; // stretch the video to fill this exact aspect-ratio rectangle
            }
        }
    }

    // Dark vignette at bottom (behind controls)
    Rectangle {
        x: 0; y: parent.height - 120px;
        width: 100%; height: 120px;
        background: @linear-gradient(0deg, rgba(0,0,0,0.65) 0%, transparent 100%);
    }
}
