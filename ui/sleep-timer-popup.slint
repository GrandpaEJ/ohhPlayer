export component SleepTimerPopup {
    in property <bool> is-open;
    in property <int> active-timer; // 0 = off, >0 = minutes
    callback timer-selected(int);
    callback controls-moved;

    width: 140px; height: 160px;

    Rectangle {
        width: 100%; height: 100%;
        background: rgba(20, 20, 25, 0.95);
        border-radius: 8px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
        opacity: root.is-open ? 1.0 : 0.0;
        visible: self.opacity > 0.01;
        animate opacity { duration: 150ms; }

        VerticalLayout {
            padding: 8px;
            spacing: 2px;

            for t[idx] in [
                { label: "Off", val: 0 },
                { label: "15 min", val: 15 },
                { label: "30 min", val: 30 },
                { label: "45 min", val: 45 },
                { label: "60 min", val: 60 }
            ] : Rectangle {
                height: 26px;
                border-radius: 4px;
                background: ta.has_hover ? rgba(255,255,255,0.15) : (root.active-timer == t.val ? rgba(0,200,255,0.2) : transparent);
                
                Text {
                    text: t.label;
                    color: root.active-timer == t.val ? #0cf : #ccc;
                    font-size: 13px;
                    x: 12px;
                    vertical-alignment: center;
                }
                
                ta := TouchArea {
                    clicked => { root.timer-selected(t.val); }
                    pointer-event(evt) => { if evt.kind == PointerEventKind.move { root.controls-moved(); } }
                }
            }
        }
    }
}
