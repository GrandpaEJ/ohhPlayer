import { VerticalBox } from "std-widgets.slint";
import { Controls } from "./controls.slint";
import { CenterPlayButton } from "./center-button.slint";
import { WindowKeyboard } from "./window-keyboard.slint";
import { VideoLayer } from "./video-layer.slint";
import { TopMenu } from "./top-menu.slint";
import { RecentFilesOverlay, RecentFile } from "./recent-files.slint";
import { KeyboardHelpOverlay } from "./keyboard-help.slint";
import { OsdOverlay } from "./osd.slint";

export component AppWindow inherits Window {
    title: "ohhPlayer";
    preferred-width: 900px;
    preferred-height: 520px;
    min-width: 50px;
    min-height: 50px;
    background: #080810;

    in-out property <image>  frame;
    in-out property <float>  position;
    in-out property <float>  duration;
    in-out property <bool>   playing;
    in-out property <string> time-text: "00:00 / 00:00";
    in-out property <float>  slider-value;
    in-out property <bool>   block-slider-update;
    in-out property <float>  controls-opacity: 1;
    in-out property <float>  center-btn-opacity: 1;
    in-out property <float>  volume-level: 0.8;
    in-out property <bool>   is-fullscreen;
    in-out property <float>  speed: 1.0;
    in property <string>     debug-text;
    in-out property <int>    scale-mode: 1;
    in property <[RecentFile]> recent-files;
    in-out property <bool>   recent-menu-open: false;
    in-out property <bool>   my-always-on-top: false;
    in-out property <int>    sleep-timer-val;
    in-out property <bool>   keyboard-help-open: false;
    in-out property <string> osd-text: "";
    in-out property <float>  osd-opacity: 0.0;

    forward-focus: my_kb;
    always-on-top: root.my-always-on-top;

    callback play-paused();
    callback seeked(float);
    callback seek-dragging(float);
    callback seek-ended(float);
    callback seek-relative(float);
    callback fullscreen-toggled();
    callback controls-moved();
    callback volume-toggled();
    callback volume-changed(float);
    callback speed-changed(float);
    callback close-window();
    callback open-file();
    callback open-recent();
    callback open-recent-file(string);
    callback always-on-top-toggled();
    callback sleep-timer-changed(int);
    callback scale-mode-changed(int);

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            my_kb := WindowKeyboard {
                play-paused        => { root.play-paused(); }
                fullscreen-toggled => { root.fullscreen-toggled(); }
                close-window       => { root.close-window(); }
                seek-relative(d)   => { root.seek-relative(d); }
                controls-moved     => { root.controls-moved(); }
                help-toggled       => { root.keyboard-help-open = !root.keyboard-help-open; }
                mute-toggled       => { root.volume-toggled(); }
                volume-step(d)     => { root.volume-changed(max(0.0, min(1.0, root.volume-level + d))); }
            }

            VideoLayer {
                frame <=> root.frame;
                scale-mode: root.scale-mode;
            }

            // ── Click / hover detection area ─────────────────────────────
            // Bug fix: TouchArea.moved only fires while the pointer is pressed.
            // Use pointer-event with PointerEventKind.move to detect FREE mouse
            // movement (no button held) and reset the controls idle timer.
            Rectangle {
                x: 0; y: 0; width: 100%; height: 100%;

                TouchArea {
                    pointer-event(evt) => {
                        // Fires on move even without any mouse button held
                        if evt.kind == PointerEventKind.move { root.controls-moved(); }
                    }
                    clicked => { root.controls-moved(); }
                }

                // Center play/pause button
                Rectangle {
                    x: (parent.width - 70px) / 2;
                    y: (parent.height - 70px) / 2;
                    width: 70px; height: 70px;
                    opacity: root.center-btn-opacity;

                    animate opacity { duration: 200ms; easing: ease-out; }

                    CenterPlayButton {
                        playing: root.playing;
                        clicked        => { root.play-paused(); }
                        controls-moved => { root.controls-moved(); }
                    }
                }

                // Controls bar pinned to bottom
                Rectangle {
                    x: 0;
                    y: parent.height - 80px;
                    width: 100%;
                    height: 80px;
                    opacity: root.controls-opacity;

                    animate opacity { duration: 300ms; easing: ease-in-out; }

                    Controls {
                        playing <=>             root.playing;
                        time-text <=>           root.time-text;
                        slider-value <=>        root.slider-value;
                        block-slider-update <=> root.block-slider-update;
                        volume-level <=>        root.volume-level;
                        is-fullscreen <=>       root.is-fullscreen;
                        speed <=>               root.speed;
                        scale-mode <=>          root.scale-mode;
                        always-on-top <=>       root.my-always-on-top;
                        sleep-timer-val <=>     root.sleep-timer-val;

                        play-paused        => { root.play-paused(); }
                        seeked(val)        => { root.seeked(val); }
                        seek-dragging(val) => { root.seek-dragging(val); }
                        seek-ended(val)    => { root.seek-ended(val); }
                        seek-relative(d)   => { root.seek-relative(d); }
                        fullscreen-toggled => { root.fullscreen-toggled(); }
                        volume-toggled     => { root.volume-toggled(); }
                        volume-changed(v)  => { root.volume-changed(v); }
                        speed-changed(s)   => { root.speed-changed(s); }
                        controls-moved     => { root.controls-moved(); }
                        always-on-top-toggled => { root.always-on-top-toggled(); }
                        sleep-timer-changed(v) => { root.sleep-timer-changed(v); }
                        scale-mode-changed(v) => { root.scale-mode-changed(v); }
                    }
                }

                // ── Close button (top-right, fades with controls) ────────────
                Rectangle {
                    x: parent.width - 42px;
                    y: 8px;
                    width: 32px;
                    height: 32px;
                    border-radius: 16px;
                    opacity: root.controls-opacity;
                    background: close-ta.has_hover
                        ? rgba(220, 60, 60, 0.85)
                        : rgba(0, 0, 0, 0.35);
                    animate background { duration: 150ms; }
                    animate opacity    { duration: 300ms; easing: ease-in-out; }

                    Text {
                        text: "✕";
                        color: close-ta.has_hover ? #fff : rgba(255,255,255,0.55);
                        font-size: 13px;
                        font-weight: 600;
                        x: (parent.width  - self.preferred-width)  / 2;
                        y: (parent.height - self.preferred-height) / 2;
                        animate color { duration: 150ms; }
                    }
                    close-ta := TouchArea {
                        pointer-event(evt) => {
                            if evt.kind == PointerEventKind.move { root.controls-moved(); }
                        }
                        clicked => { root.close-window(); }
                    }
                }

                // ── Top Menu (top-left, Hamburger) ───────────────────────────
                TopMenu {
                    x: 12px;
                    y: 8px;
                    scale-mode <=> root.scale-mode;
                    controls-opacity: root.controls-opacity;
                    open-file => { root.open-file(); }
                    open-recent => { root.recent-menu-open = true; }
                    controls-moved => { root.controls-moved(); }
                }

                // ── Debug Overlay (Top Right, left of close button) ──────────
                Rectangle {
                    x: parent.width - self.preferred-width - 55px;
                    y: 12px;
                    width: debug_txt.preferred-width + 12px;
                    height: debug_txt.preferred-height + 6px;
                    background: rgba(0, 0, 0, 0.4);
                    border-radius: 4px;
                    opacity: root.debug-text == "" ? 0.0 : 1.0;

                    debug_txt := Text {
                        text: root.debug-text;
                        color: #0f0; // Hacker green for show off
                        font-size: 11px;
                        font-weight: 700;
                        x: (parent.width - self.preferred-width) / 2;
                        y: (parent.height - self.preferred-height) / 2;
                    }
                }

                // ── Recent Files Overlay ─────────────────────────────────────
                RecentFilesOverlay {
                    x: 0; y: 0; width: 100%; height: 100%;
                    files: root.recent-files;
                    is-open: root.recent-menu-open;
                    close-clicked => { root.recent-menu-open = false; }
                    file-clicked(path) => { root.open-recent-file(path); }
                }

                // ── Keyboard Help Overlay ────────────────────────────────────
                KeyboardHelpOverlay {
                    is-open: root.keyboard-help-open;
                    close-clicked => { root.keyboard-help-open = false; }
                    controls-moved => { root.controls-moved(); }
                }

                // ── OSD Overlay ──────────────────────────────────────────────
                OsdOverlay {
                    text: root.osd-text;
                    osd-opacity: root.osd-opacity;
                }

            }
        }
    }
}
