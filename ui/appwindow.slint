import { Slider, HorizontalBox, VerticalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "ohhPlayer";
    preferred-width: 900px;
    preferred-height: 520px;
    background: #0a0a12;


    in-out property <image> frame;
    in-out property <float> position;
    in-out property <float> duration;
    in-out property <bool> playing;
    in-out property <string> time-text: "00:00 / 00:00";
    in-out property <float> slider-value;
    in-out property <bool> block-slider-update;
    in-out property <float> controls-opacity: 1;
    in-out property <float> center-btn-opacity: 1;
    in-out property <float> volume-level: 0.8;
    in-out property <bool> is-fullscreen;
    in-out property <bool> is-maximized;

    callback play-paused();
    callback seeked(float);
    callback fullscreen-toggled();
    callback seek-relative(float);
    callback controls-moved();
    callback volume-toggled();
    callback close-window();
    callback maximize-window();
    callback minimize-window();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            FocusScope {
                key-pressed(event) => {
                    if event.text == " " { root.play-paused(); return accept; }
                    if event.text == "f" || event.text == "F" { root.fullscreen-toggled(); return accept; }
                    if event.text == "Escape" { root.close-window(); return accept; }
                    if event.text == "j" { root.seek-relative(-10); return accept; }
                    if event.text == "l" { root.seek-relative(10); return accept; }
                    if event.text == "," { root.seek-relative(-5); return accept; }
                    if event.text == "." { root.seek-relative(5); return accept; }
                    return reject;
                }
            }

            Rectangle {
                width: 100%;
                height: 100%;

                Image {
                    source: root.frame;
                    width: 100%;
                    height: 100%;
                    image-fit: contain;
                }

                Rectangle {
                    x: 0px; y: 0px;
                    width: 100%; height: 100%;
                    opacity: 0.2;
                    background: #000;
                }

                Rectangle {
                    x: 0px; y: 0px;
                    width: 100%; height: 100%;

                    TouchArea {
                        moved => { root.controls-moved(); }
                    }

                    Rectangle {
                        x: (parent.width - 70px) / 2;
                        y: (parent.height - 70px) / 2;
                        width: 70px;
                        height: 70px;
                        opacity: root.center-btn-opacity;

                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-color: rgba(255, 255, 255, 0.45);
                            border-width: 2px;
                            background: rgba(0, 0, 0, 0.45);

                            Text {
                                text: root.playing ? "⏸" : "▶";
                                color: #fff;
                                font-size: 30px;
                                x: (parent.width - self.preferred-width) / 2;
                                y: (parent.height - self.preferred-height) / 2;
                            }

                            TouchArea {
                                moved => { root.controls-moved(); }
                                clicked => { root.play-paused(); }
                            }
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: parent.height - 56px;
                        width: 100%;
                        height: 56px;
                        opacity: root.controls-opacity;

                        Rectangle {
                            width: 100%;
                            height: 100%;
                            background: rgba(8, 8, 18, 0.88);
                        }

                        HorizontalBox {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            alignment: center;

                            Rectangle {
                                width: 40px; height: 36px;
                                background: rgba(255, 255, 255, 0.06);

                                Text {
                                    text: root.playing ? "⏸" : "▶";
                                    color: #eee;
                                    font-size: 17px;
                                    x: (parent.width - self.preferred-width) / 2;
                                    y: (parent.height - self.preferred-height) / 2;
                                }

                                TouchArea {
                                    moved => { root.controls-moved(); }
                                    clicked => { root.play-paused(); }
                                }
                            }

                            Text {
                                text: root.time-text;
                                color: #aaa;
                                font-size: 12px;
                                vertical-alignment: center;
                                min-width: 105px;
                                horizontal-alignment: center;
                            }

                            Slider {
                                minimum: 0;
                                maximum: 1;
                                value: root.slider-value;
                                changed(new-val) => {
                                    root.controls-moved();
                                    if !root.block-slider-update {
                                        root.seeked(new-val);
                                    }
                                }
                            }

                            Rectangle {
                                width: 28px; height: 28px;

                                Text {
                                    text: root.volume-level > 0 ? "🔊" : "🔇";
                                    color: #ccc;
                                    font-size: 14px;
                                    x: (parent.width - self.preferred-width) / 2;
                                    y: (parent.height - self.preferred-height) / 2;
                                }

                                TouchArea {
                                    moved => { root.controls-moved(); }
                                    clicked => { root.volume-toggled(); }
                                }
                            }

                            Rectangle {
                                width: 36px; height: 36px;
                                background: rgba(255, 255, 255, 0.06);

                                Text {
                                    text: root.is-fullscreen ? "⧉" : "⛶";
                                    color: #ccc;
                                    font-size: 15px;
                                    x: (parent.width - self.preferred-width) / 2;
                                    y: (parent.height - self.preferred-height) / 2;
                                }

                                TouchArea {
                                    moved => { root.controls-moved(); }
                                    clicked => { root.fullscreen-toggled(); }
                                }
                            }

                            Rectangle {
                                width: 36px; height: 36px;
                                background: rgba(255, 255, 255, 0.06);

                                Text {
                                    text: "✕";
                                    color: #e55;
                                    font-size: 15px;
                                    x: (parent.width - self.preferred-width) / 2;
                                    y: (parent.height - self.preferred-height) / 2;
                                }

                                TouchArea {
                                    moved => { root.controls-moved(); }
                                    clicked => { root.close-window(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
